# ==============================================
# Infra - 环境变量配置模板
# ==============================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改以下配置为你的实际值
# 3. 不要将 .env 文件提交到 Git 仓库
# ==============================================

# --------------------
# 项目配置
# --------------------
PROJECT_NAME=infra
ENVIRONMENT=development

# --------------------
# MySQL 配置
# --------------------
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=your_secure_db_password_here
MYSQL_PORT=3306

# MySQL 时区（默认：+08:00）
MYSQL_TZ=+08:00

# --------------------
# Redis 配置
# --------------------
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# --------------------
# Neo4j 配置
# --------------------
# Neo4j 认证（格式：username/password）
NEO4J_AUTH=neo4j/your_secure_neo4j_password_here

# Neo4j 端口
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Neo4j 内存配置
NEO4J_HEAP_SIZE=512m
NEO4J_HEAP_MAX_SIZE=1G
NEO4J_PAGECACHE_SIZE=512m

# --------------------
# 备份配置
# --------------------
# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 备份路径
BACKUP_PATH=./backup

# --------------------
# 日志配置
# --------------------
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 日志最大大小（MB）
LOG_MAX_SIZE=100

# 日志保留天数
LOG_RETENTION_DAYS=30

# --------------------
# 网络配置
# --------------------
# Docker 网络名称
NETWORK_NAME=infra_network

# --------------------
# 资源限制（可选）
# --------------------
# MySQL 内存限制
MYSQL_MEMORY_LIMIT=1g

# Redis 内存限制
REDIS_MEMORY_LIMIT=256m
